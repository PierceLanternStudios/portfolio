---
interface Props {
  name: string;
  tagline: string;
  ctaText: string;
  ctaLink: string;
  image?: string;
}

const { name, tagline, ctaText, ctaLink, image } = Astro.props;
---

<section
  class="hero"
  style={image ? `background-image: url(${image})` : ''}
>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <h1>{name}</h1>
    <p class="tagline">{tagline}</p>
    <a href={ctaLink} class="cta">{ctaText}</a>
  </div>
</section>
