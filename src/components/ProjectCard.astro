---
interface Props {
  title: string;
  description: string;
  image?: string;
  tags: string[];
  link?: string;
}

const { title, description, image, tags, link } = Astro.props;
const Tag = link ? 'a' : 'div';
---

<Tag href={link || undefined} target={link ? '_blank' : undefined} rel={link ? 'noopener noreferrer' : undefined} class={`project-card${link ? '' : ' project-card--static'}`}>
  {image ? (
    <img src={image} alt={`Screenshot of ${title}`} class="project-card-image" />
  ) : (
    <div class="project-card-image" role="img" aria-label={`Placeholder for ${title}`}></div>
  )}
  <div class="project-card-content">
    <h3>{title}</h3>
    <p>{description}</p>
    <div class="tags">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
  </div>
</Tag>
