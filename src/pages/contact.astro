---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<Layout title="Contact">
  <section class="section">
    <div class="container">
      <SectionHeading title="Contact Me" subtitle="Have a question or want to work together? Get in touch." />
      <div class="contact-info">
        <a href="mailto:pierceclark07@gmail.com" class="contact-info-item">
          <span class="contact-info-label">Email</span>
          <span class="contact-info-value">pierceclark07@gmail.com</span>
        </a>
        <a href="https://www.linkedin.com/in/pierce-clark/" target="_blank" rel="noopener noreferrer" class="contact-info-item">
          <span class="contact-info-label">LinkedIn</span>
          <span class="contact-info-value">pierce-clark</span>
        </a>
        <a href="https://github.com/PierceLanternStudios" target="_blank" rel="noopener noreferrer" class="contact-info-item">
          <span class="contact-info-label">GitHub</span>
          <span class="contact-info-value">PierceLanternStudios</span>
        </a>
      </div>
    </div>
  </section>
</Layout>
