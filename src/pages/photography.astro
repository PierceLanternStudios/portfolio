<Layout title="Photography">
  <section class="section">
    <div class="container">
      <SectionHeading title="Photography" subtitle="A selection of some of my film photography. Photos were captured on a Ricoh KR-10 (35mm) or a Hasselblad 500elx (120mm). " />
      <div class="photo-gallery">
        {photos.map(file => (
          <figure class="photo-item">
            <img src={`/images/gallery/${file}`} alt="Photograph by Pierce Clark" loading="lazy" data-lightbox />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <div class="lightbox" id="lightbox">
    <img src="" alt="" />
  </div>

  <script>
    const gallery = document.querySelector('.photo-gallery')!;
    const items = [...gallery.children];
    for (let i = items.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      gallery.appendChild(items[j]);
      items[j] = items[i];
    }

    const lightbox = document.getElementById('lightbox')!;
    const lightboxImg = lightbox.querySelector('img')!;

    document.querySelectorAll('[data-lightbox]').forEach(img => {
      img.addEventListener('click', () => {
        lightboxImg.src = (img as HTMLImageElement).src;
        lightboxImg.alt = (img as HTMLImageElement).alt;
        lightbox.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
    });

    lightbox.addEventListener('click', () => {
      lightbox.classList.remove('active');
      document.body.style.overflow = '';
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox.classList.contains('active')) {
        lightbox.classList.remove('active');
        document.body.style.overflow = '';
      }
    });
  </script>
</Layout>
